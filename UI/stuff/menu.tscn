[sub_resource type="GDScript" id="GDScript_qa2pn"]
script/source = "extends Panel

var LobbyName = \"Lobby\"
var LobbyPassword = \"\"
var privateLobby = false

func _on_button_pressed() -> void:
	LobbyName = $LobbyName.text if $LobbyName.text != \"\" else \"Lobby\"
	LobbyPassword = $Password.text if privateLobby else \"\"
	
	var username = Auth.current_user.get(\"email\", \"player\").replace(\"@fuckyou.com\", \"\")
	LobbyManager.host_lobby(username)
	
	ServerSettings.server_owner_id = multiplayer.get_unique_id()
	ServerSettings.server_owner_name = username
	
	Input.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)
	
	visible = false
	$\"..\".visible = false

func _on_private_toggled(toggled_on: bool) -> void:
	$Password.visible = toggled_on
	privateLobby = toggled_on

func _on_lobby_settings_pressed() -> void:
	$\"../ServerSettings\".visible = true

func _on_use_stam_toggled(toggled_on: bool) -> void:
	ServerSettings.use_stamina = toggled_on

func _on_use_bots_toggled(toggled_on: bool) -> void:
	ServerSettings.enable_bots = toggled_on

func _on_exits_toggled(toggled_on: bool) -> void:
	ServerSettings.exits = toggled_on

func _on_back_pressed() -> void:
	$\".\".visible = false
	$\"../MainMenu\".visible = true
"

[sub_resource type="GDScript" id="GDScript_350d7"]
script/source = "extends Panel

func _on_join_button_pressed() -> void:
	var username = Auth.current_user.get(\"email\", \"player\").replace(\"@fuckyou.com\", \"\")
	LobbyManager.join_lobby($LobbyName.text, username)
	Input.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)
	
	visible = false
	$\"..\".visible = false

func _on_back_pressed() -> void:
	$\".\".visible = false
	$\"../MainMenu\".visible = true
"

