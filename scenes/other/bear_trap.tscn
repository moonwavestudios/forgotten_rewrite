[gd_scene format=3 uid="uid://cuf6o073xuvjg"]

[sub_resource type="GDScript" id="GDScript_1qqd5"]
script/source = "extends Area3D

var owner_player
var damage := 15
var hitboxes_scene

var triggered := false

func _ready():
	add_to_group(\"beartraps\")
	body_entered.connect(_on_body_entered)

func _on_body_entered(body):
	if triggered:
		return

	if body == owner_player:
		return

	if not (\"is_Killer\" in body):
		return

	if body.is_Killer:
		return

	triggered = true

	print(\"Beartrap triggered!\")

	body.take_damage(damage)

	if \"current_speed\" in body:
		var old_speed = body.current_speed
		body.current_speed = 0

		await get_tree().create_timer(2.0).timeout

		if is_instance_valid(body):
			body.current_speed = old_speed

	queue_free()
"

